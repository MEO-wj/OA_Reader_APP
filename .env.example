# 每个部署目录维护自己的 .env（目录间天然隔离）
# 复制本文件为 .env 后直接 `docker compose up -d`

# ---- Compose 资源隔离 ----
COMPOSE_PROJECT_NAME=oap-dev
DOCKER_SUBNET=10.200.0.0/16

# ---- Host 端口 ----
HOST_POSTGRES_PORT=55430
HOST_BACKEND_PORT=14420

# ---- Postgres ----
POSTGRES_DB=oa-reader
POSTGRES_USER=Unself
POSTGRES_PASSWORD=change-me
TZ=Asia/Shanghai

# ---- Backend ----
AUTH_JWT_SECRET=change-me-jwt-secret
AUTH_REFRESH_HASH_KEY=change-me-refresh-hash-key
AUTH_ACCESS_TOKEN_TTL=168h
AUTH_REFRESH_TOKEN_TTL=168h
AUTH_PASSWORD_COST=12
AUTH_ALLOW_AUTO_USER_CREATION=true

CAMPUS_AUTH_ENABLED=true
CAMPUS_AUTH_TIMEOUT=10

CORS_ALLOW_ORIGINS=*
RATE_LIMIT_PER_DAY=1000
RATE_LIMIT_PER_HOUR=100
AI_END_URL=http://ai_end:4421
PUBLIC_BASE_URL=http://localhost:14420
UPLOAD_ROOT_DIR=uploads
AUTH_DEBUG=false

# ---- AI End ----
HOST_AI_END_PORT=14421

OPENAI_API_KEY=change-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=deepseek-v3.2

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024

RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MAX_CANDIDATES=40

AI_AUTO_MIGRATE=true
AI_AUTO_IMPORT=true
