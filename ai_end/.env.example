OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=your-base-url
OPENAI_MODEL=glm-4.7

# Embedding 模型配置 (BAAI/bge-m3)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
# 如果使用不同的 embedding API，可以单独配置
# EMBEDDING_API_KEY=your-embedding-api-key
# EMBEDDING_BASE_URL=your-embedding-base-url

# Rerank 模型配置 (BAAI/bge-reranker-v2-m3)
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MAX_CANDIDATES=40
RERANK_TIMEOUT=60.0
# 如果使用不同的 rerank API，可以单独配置
# RERANK_BASE_URL=your-rerank-base-url

# 数据库配置 - 连接外部 PostgreSQL (pgvector)
# Docker Compose 不包含数据库服务，需指向外部 PostgreSQL 实例
DB_HOST=localhost
DB_PORT=5432
DB_USER=oa
DB_PASSWORD=oa
DB_NAME=oa

# API 启动时自动执行迁移与结构对齐（建议本地开发开启）
AUTO_MIGRATE=true

# API 启动时自动执行文档导入（建议本地开发开启）
AUTO_IMPORT=true