# 爬虫运行配置（放置于 crawler/.env）
SMTP_SERVER=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_smtp_username@example.com
SMTP_PASSWORD=your_smtp_password

# AI/LLM
API_KEY=your_glm_api_key
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
AI_MODEL=glm-4.5-flash
# AI多模型配置（JSON数组，必须单行）
# AI_MODELS=[{"api_key":"sk-key1","base_url":"https://api1.com/v1/chat/completions","models":["glm-4.5-flash","glm-4-plus"]},{"api_key":"sk-key2","base_url":"https://api2.com/v1/chat/completions","models":["qwen-max"]}]
# AI_ENABLE_LOAD_BALANCING=true

# 数据库
DATABASE_URL=postgresql://user:pass@host:5432/oap

# 嵌入向量
EMBED_BASE_URL=https://api.openai.com/v1/embeddings
EMBED_MODEL=text-embedding-model
EMBED_API_KEY=your_embed_key
EMBED_DIM=1024

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ========================================
# 回填配置 (Backfill Configuration)
# ========================================
# 回填起始日期 (YYYY-MM-DD)
BACKFILL_START_DATE=2024-01-01
# 回填结束日期 (YYYY-MM-DD)
BACKFILL_END_DATE=2024-12-31
# 每次爬几天 (推荐: 1-3)
BACKFILL_BATCH_SIZE=5
# 详情页最小延迟(秒) (推荐: 2-5)
BACKFILL_DELAY_MIN=2.0
# 详情页最大延迟(秒) (推荐: 5-10)
BACKFILL_DELAY_MAX=5.0
# 天间最小延迟(秒) (推荐: 60-180)
BACKFILL_DAY_DELAY_MIN=60
# 天间最大延迟(秒) (推荐: 180-300)
BACKFILL_DAY_DELAY_MAX=180
# 是否启用随机延迟 (推荐: true)
BACKFILL_ENABLE_RANDOM_DELAY=true

# 可选覆盖
# EVENTS_DIR=./events
# RECIPIENT_LIST=./List.txt
