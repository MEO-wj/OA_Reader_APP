# AI/LLM - 单模型配置（向后兼容，fallback 模式下不使用）
API_KEY=xxx
AI_BASE_URL=http://186.1.1.2:4417/v1/completions
AI_MODEL=glm-4.6v-flash

# 主力模型（优先使用）
AI_PRIMARY_API_KEY=xxx
AI_PRIMARY_BASE_URL=http://186.1.1.2:4417/v1/chat/completions
AI_PRIMARY_MODEL=minimax-m2.5

# 兜底模型（主力失败时使用，请替换为实际配置）
AI_FALLBACK_API_KEY=your-fallback-api-key
AI_FALLBACK_BASE_URL=https://api.openai.com/v1/chat/completions
AI_FALLBACK_MODEL=gpt-4o-mini


# 数据库
# DATABASE_URL=postgresql://handy:hyh520888@172.29.147.195:5431/OAP
DATABASE_URL=postgres://oa:oa@localhost:5432/oa?sslmode=disable

# 嵌入向量
EMBED_BASE_URL=http://186.1.1.2:4417/v1/embeddings
EMBED_MODEL=BAAI/bge-m3
EMBED_API_KEY=xxx
EMBED_DIM=1024


# ========================================
# 回填配置 (Backfill Configuration)
# ========================================
# 回填起始日期 (YYYY-MM-DD)
BACKFILL_START_DATE=2025-01-01
# 回填结束日期 (YYYY-MM-DD)
BACKFILL_END_DATE=2025-12-23
# 每次爬几天 (推荐: 1-3)
BACKFILL_BATCH_SIZE=5
# 详情页最小延迟(秒) (推荐: 2-5)
BACKFILL_DELAY_MIN=2.0
# 详情页最大延迟(秒) (推荐: 5-10)
BACKFILL_DELAY_MAX=5.0
# 天间最小延迟(秒) (推荐: 60-180)
BACKFILL_DAY_DELAY_MIN=1
# 天间最大延迟(秒) (推荐: 180-300)
BACKFILL_DAY_DELAY_MAX=3
# 是否启用随机延迟 (推荐: true)
BACKFILL_ENABLE_RANDOM_DELAY=true