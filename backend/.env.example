# 数据库连接（Docker 内部网络）
DATABASE_URL=postgres://Unself:Unself-oa-reader-5@postgres:5432/oa-reader?sslmode=disable

# JWT 配置
AUTH_JWT_SECRET=your-jwt-secret-key-change-in-production
AUTH_ACCESS_TOKEN_TTL=168h

# 密码加密
AUTH_PASSWORD_COST=12

# 用户创建
AUTH_ALLOW_AUTO_USER_CREATION=true

# 校园认证
CAMPUS_AUTH_ENABLED=true
CAMPUS_AUTH_URL=http://a.stu.edu.cn/ac_portal/login.php
CAMPUS_AUTH_TIMEOUT=10

# CORS
CORS_ALLOW_ORIGINS=*

# 限流
RATE_LIMIT_PER_DAY=1000
RATE_LIMIT_PER_HOUR=100

# AI 服务地址
AI_END_URL=http://ai_end:4421

# 头像等上传文件的本地存储目录
UPLOAD_ROOT_DIR=uploads

# 调试
AUTH_DEBUG=false
